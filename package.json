{
  "name": "pubmed-seed-mcp-app",
  "version": "1.0.0",
  "description": "MCP App for building systematic review search strings from PubMed seed articles",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.server.json && cross-env INPUT=mcp-app.html vite build",
    "start": "concurrently --raw \"cross-env NODE_ENV=development INPUT=mcp-app.html vite build --watch\" \"tsx watch main.ts\"",
    "start:stdio": "tsx main.ts --stdio",
    "preview": "node dist/main.js",
    "serve": "tsx main.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xmldom/xmldom": "latest",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/xmldom": "^0.1.34",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.0.2"
  }
}
